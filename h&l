<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Generador de Cotizaciones - Inversiones H & L</title>
<link href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.8.2/jspdf.plugin.autotable.min.js"></script>
<style>
  :root {
    --gold: #C9A84C;
    --gold-light: #E8C97A;
    --dark: #0F1117;
    --dark2: #181C26;
    --dark3: #222839;
    --text: #E8E8F0;
    --text-muted: #8890A8;
    --border: #2E3548;
    --accent: #3A5BF0;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
  }

  header {
    background: linear-gradient(135deg, var(--dark2), var(--dark3));
    border-bottom: 2px solid var(--gold);
    padding: 20px 40px;
    display: flex;
    align-items: center;
    gap: 20px;
  }

  .header-text h1 {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 28px;
    letter-spacing: 2px;
    color: var(--gold);
  }

  .header-text p {
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 1px;
    text-transform: uppercase;
  }

  .container {
    max-width: 900px;
    margin: 40px auto;
    padding: 0 20px;
  }

  .section {
    background: var(--dark2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    margin-bottom: 24px;
  }

  .section-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 18px;
    letter-spacing: 2px;
    color: var(--gold);
    margin-bottom: 20px;
    padding-bottom: 10px;
    border-bottom: 1px solid var(--border);
  }

  .grid-2 {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field label {
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
  }

  .field input, .field select, .field textarea {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 10px 14px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    transition: border-color 0.2s;
  }

  .field input:focus, .field select:focus, .field textarea:focus {
    outline: none;
    border-color: var(--gold);
  }

  .field select option { background: var(--dark3); }

  /* Equipment table */
  .equip-table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 16px;
  }

  .equip-table th {
    background: var(--dark3);
    padding: 10px 12px;
    text-align: left;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--text-muted);
    font-weight: 600;
  }

  .equip-table td {
    padding: 8px 12px;
    border-bottom: 1px solid var(--border);
    vertical-align: middle;
  }

  .equip-table tr:hover td { background: rgba(201,168,76,0.04); }

  .equip-table input, .equip-table select {
    background: var(--dark3);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 7px 10px;
    color: var(--text);
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    width: 100%;
  }

  .equip-table input:focus, .equip-table select:focus {
    outline: none;
    border-color: var(--gold);
  }

  .price-display {
    color: var(--gold-light);
    font-weight: 600;
    font-size: 14px;
    text-align: right;
  }

  .btn-remove {
    background: none;
    border: 1px solid #c0392b;
    color: #c0392b;
    padding: 5px 10px;
    border-radius: 6px;
    cursor: pointer;
    font-size: 16px;
    transition: all 0.2s;
  }
  .btn-remove:hover { background: #c0392b; color: white; }

  .btn-add {
    background: none;
    border: 1px dashed var(--gold);
    color: var(--gold);
    padding: 10px 20px;
    border-radius: 8px;
    cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.2s;
    width: 100%;
  }
  .btn-add:hover { background: rgba(201,168,76,0.1); }

  .totals {
    background: var(--dark3);
    border-radius: 10px;
    padding: 20px;
    margin-top: 16px;
  }

  .total-row {
    display: flex;
    justify-content: space-between;
    padding: 6px 0;
    font-size: 14px;
    color: var(--text-muted);
  }

  .total-row.final {
    border-top: 1px solid var(--gold);
    margin-top: 8px;
    padding-top: 12px;
    font-size: 18px;
    font-weight: 700;
    color: var(--gold);
  }

  .btn-generate {
    background: linear-gradient(135deg, var(--gold), var(--gold-light));
    border: none;
    color: var(--dark);
    padding: 16px 40px;
    border-radius: 10px;
    cursor: pointer;
    font-family: 'Bebas Neue', sans-serif;
    font-size: 20px;
    letter-spacing: 2px;
    width: 100%;
    transition: all 0.2s;
    margin-top: 8px;
  }
  .btn-generate:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(201,168,76,0.3);
  }

  .nota {
    background: rgba(201,168,76,0.08);
    border-left: 3px solid var(--gold);
    padding: 12px 16px;
    border-radius: 0 8px 8px 0;
    font-size: 13px;
    color: var(--text-muted);
    margin-top: 16px;
  }

  @media (max-width: 600px) {
    .grid-2 { grid-template-columns: 1fr; }
    header { padding: 16px 20px; }
    .container { padding: 0 12px; }
  }
</style>
</head>
<body>

<header>
  <div class="header-text">
    <h1>Inversiones H & L</h1>
    <p>Generador de Cotizaciones · Ingenieros y Arquitectos</p>
  </div>
</header>

<div class="container">

  <!-- Datos del cliente -->
  <div class="section">
    <div class="section-title">📋 Datos del Cliente</div>
    <div class="grid-2">
      <div class="field">
        <label>Empresa / Nombre</label>
        <input type="text" id="clienteNombre" placeholder="Ej: IMFICA INDUSTRIAL S.A DE C.V">
      </div>
      <div class="field">
        <label>Atención a (Ing./Lic.)</label>
        <input type="text" id="clienteContacto" placeholder="Ej: Ing. Oscar Hernández">
      </div>
      <div class="field">
        <label>Lugar de cotización</label>
        <input type="text" id="lugar" placeholder="Ej: Nueva Guadalupe, San Miguel" value="Nueva Guadalupe, San Miguel">
      </div>
      <div class="field">
        <label>Fecha</label>
        <input type="date" id="fecha">
      </div>
      <div class="field" style="grid-column: span 2;">
        <label>Notas adicionales (opcional)</label>
        <input type="text" id="notas" placeholder="Ej: Precios válidos por 30 días">
      </div>
    </div>
  </div>

  <!-- Equipos -->
  <div class="section">
    <div class="section-title">🚧 Equipos y Servicios</div>

    <table class="equip-table">
      <thead>
        <tr>
          <th style="width:35%">Descripción</th>
          <th style="width:15%">Cantidad</th>
          <th style="width:18%">Unidad</th>
          <th style="width:17%">P. Unitario</th>
          <th style="width:12%">Subtotal</th>
          <th style="width:3%"></th>
        </tr>
      </thead>
      <tbody id="equiposBody"></tbody>
    </table>

    <button class="btn-add" onclick="agregarFila()">+ Agregar equipo / servicio</button>

    <div class="totals">
      <div class="total-row">
        <span>Subtotal</span>
        <span id="subtotalDisplay">$0.00</span>
      </div>
      <div class="total-row">
        <span>IVA (13%)</span>
        <span id="ivaDisplay">$0.00</span>
      </div>
      <div class="total-row final">
        <span>TOTAL</span>
        <span id="totalDisplay">$0.00</span>
      </div>
    </div>

    <div class="nota">
      ⚠️ <strong>Nota:</strong> Los precios son más IVA · Maquinaria: 4 horas mínimas
    </div>
  </div>

  <button class="btn-generate" onclick="generarPDF()">⬇ GENERAR COTIZACIÓN PDF</button>

</div>

<script>
const equiposCatalogo = [
  { nombre: "ALQUILER MOTONIVELADORA [JOHN DEER 570B]", precio: 60, unidad: "HORA" },
  { nombre: "RETROEXCAVADORA [HYL MODELO ML]", precio: 55, unidad: "HORA" },
  { nombre: "CAMION [SCHACMAN 24 M3]", precio: 280, unidad: "DIA" },
  { nombre: "CONCRETERA DE 1 BOLSA", precio: 19, unidad: "DIA" },
  { nombre: "ROTOMARTILLO [BOSCH]", precio: 45, unidad: "DIA" },
  { nombre: "MINICARGADOR [BOBCAT]", precio: 35, unidad: "HORA" },
  { nombre: "OTRO / PERSONALIZADO", precio: 0, unidad: "DIA" },
];

// Set today's date
document.getElementById('fecha').valueAsDate = new Date();

let filaCount = 0;

function agregarFila(nombre='', cantidad=1, unidad='HORA', precio=0) {
  filaCount++;
  const tbody = document.getElementById('equiposBody');
  const tr = document.createElement('tr');
  tr.id = `fila-${filaCount}`;

  const selectOpts = equiposCatalogo.map(e =>
    `<option value="${e.nombre}" data-precio="${e.precio}" data-unidad="${e.unidad}" ${e.nombre===nombre?'selected':''}>${e.nombre}</option>`
  ).join('');

  tr.innerHTML = `
    <td>
      <select onchange="onEquipoChange(this, ${filaCount})">
        ${selectOpts}
      </select>
      <input type="text" id="custom-${filaCount}" placeholder="Descripción personalizada" style="margin-top:5px; display:${nombre&&!equiposCatalogo.find(e=>e.nombre===nombre)?'block':'none'}">
    </td>
    <td><input type="number" id="cant-${filaCount}" value="${cantidad}" min="0.5" step="0.5" onchange="calcularTotales()"></td>
    <td>
      <select id="unidad-${filaCount}" onchange="calcularTotales()">
        <option value="HORA" ${unidad==='HORA'?'selected':''}>HORA</option>
        <option value="DIA" ${unidad==='DIA'?'selected':''}>DIA</option>
        <option value="M3" ${unidad==='M3'?'selected':''}>M3</option>
        <option value="ML" ${unidad==='ML'?'selected':''}>ML</option>
        <option value="GLOBAL" ${unidad==='GLOBAL'?'selected':''}>GLOBAL</option>
      </select>
    </td>
    <td><input type="number" id="precio-${filaCount}" value="${precio}" min="0" step="0.01" onchange="calcularTotales()"></td>
    <td class="price-display" id="subtotal-${filaCount}">$0.00</td>
    <td><button class="btn-remove" onclick="eliminarFila(${filaCount})">×</button></td>
  `;
  tbody.appendChild(tr);

  // Set initial values from catalog
  const sel = tr.querySelector('select');
  onEquipoChange(sel, filaCount);
  if (precio > 0) document.getElementById(`precio-${filaCount}`).value = precio;
  calcularTotales();
}

function onEquipoChange(sel, id) {
  const opt = sel.options[sel.selectedIndex];
  const precioInput = document.getElementById(`precio-${id}`);
  const unidadSel = document.getElementById(`unidad-${id}`);
  const customInput = document.getElementById(`custom-${id}`);

  if (sel.value === 'OTRO / PERSONALIZADO') {
    customInput.style.display = 'block';
    precioInput.value = 0;
  } else {
    customInput.style.display = 'none';
    precioInput.value = opt.dataset.precio || 0;
    const u = opt.dataset.unidad || 'HORA';
    for (let o of unidadSel.options) { o.selected = o.value === u; }
  }
  calcularTotales();
}

function eliminarFila(id) {
  document.getElementById(`fila-${id}`)?.remove();
  calcularTotales();
}

function calcularTotales() {
  let subtotal = 0;
  for (let i = 1; i <= filaCount; i++) {
    const cant = parseFloat(document.getElementById(`cant-${i}`)?.value || 0);
    const precio = parseFloat(document.getElementById(`precio-${i}`)?.value || 0);
    const sub = cant * precio;
    const el = document.getElementById(`subtotal-${i}`);
    if (el) el.textContent = `$${sub.toFixed(2)}`;
    subtotal += sub;
  }
  const iva = subtotal * 0.13;
  const total = subtotal + iva;
  document.getElementById('subtotalDisplay').textContent = `$${subtotal.toFixed(2)}`;
  document.getElementById('ivaDisplay').textContent = `$${iva.toFixed(2)}`;
  document.getElementById('totalDisplay').textContent = `$${total.toFixed(2)}`;
}

function getFilas() {
  const filas = [];
  for (let i = 1; i <= filaCount; i++) {
    const selEl = document.querySelector(`#fila-${i} select`);
    if (!selEl) continue;
    let desc = selEl.value === 'OTRO / PERSONALIZADO'
      ? document.getElementById(`custom-${i}`)?.value || 'Servicio'
      : selEl.value;
    const cant = parseFloat(document.getElementById(`cant-${i}`)?.value || 0);
    const unidad = document.getElementById(`unidad-${i}`)?.value || 'HORA';
    const precio = parseFloat(document.getElementById(`precio-${i}`)?.value || 0);
    const sub = cant * precio;
    filas.push({ desc, cant, unidad, precio, sub });
  }
  return filas;
}

async function generarPDF() {
  const { jsPDF } = window.jspdf;
  const doc = new jsPDF({ orientation: 'portrait', unit: 'mm', format: 'letter' });

  const W = 215.9, H = 279.4;
  const margin = 18;

  // Colors
  const gold = [201, 168, 76];
  const dark = [15, 17, 23];
  const darkBlue = [20, 30, 60];
  const white = [255, 255, 255];
  const lightGray = [245, 245, 248];
  const midGray = [180, 185, 200];

  // Background
  doc.setFillColor(...lightGray);
  doc.rect(0, 0, W, H, 'F');

  // Header bar
  doc.setFillColor(...darkBlue);
  doc.rect(0, 0, W, 38, 'F');

  // Gold accent line
  doc.setFillColor(...gold);
  doc.rect(0, 38, W, 1.5, 'F');

  // Try to load logo
  try {
    doc.addImage('data:image/png;base64,', 'PNG', margin, 4, 30, 30);
  } catch(e) {}

  // Company name
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(16);
  doc.setTextColor(...gold);
  doc.text('INVERSIONES H & L', 55, 14);

  doc.setFontSize(10);
  doc.setTextColor(...white);
  doc.text('INGENIEROS Y ARQUITECTOS S.A DE C.V', 55, 20);

  doc.setFontSize(8);
  doc.setTextColor(180, 195, 220);
  doc.text('Final 6a. Avenida Sur y 4a. Calle Oriente Bo. El Centro, Nueva Guadalupe, San Miguel', 55, 26);
  doc.text('Tel: +503 7528-3295 / 7244-1037  ·  hylingyarq@yahoo.com  ·  NIT: 1210-210715-101-2', 55, 31);

  // COTIZACIÓN label
  doc.setFillColor(...gold);
  doc.roundedRect(W - margin - 38, 6, 38, 14, 2, 2, 'F');
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(10);
  doc.setTextColor(...dark);
  doc.text('COTIZACIÓN', W - margin - 19, 14, { align: 'center' });
  doc.setFontSize(8);
  doc.text('No. ' + String(Date.now()).slice(-6), W - margin - 19, 19, { align: 'center' });

  // Date and place
  const fecha = document.getElementById('fecha').value;
  const lugar = document.getElementById('lugar').value || 'Nueva Guadalupe, San Miguel';
  const fechaFmt = fecha ? new Date(fecha + 'T00:00:00').toLocaleDateString('es-SV', { day: '2-digit', month: 'long', year: 'numeric' }) : '';

  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(...darkBlue);
  doc.text(`${lugar}, ${fechaFmt}`, W - margin, 48, { align: 'right' });

  // Client box
  const clienteNombre = document.getElementById('clienteNombre').value;
  const clienteContacto = document.getElementById('clienteContacto').value;

  doc.setFillColor(...white);
  doc.roundedRect(margin, 52, W - margin * 2, 22, 2, 2, 'F');
  doc.setDrawColor(...gold);
  doc.setLineWidth(0.5);
  doc.roundedRect(margin, 52, W - margin * 2, 22, 2, 2, 'S');

  doc.setFont('helvetica', 'bold');
  doc.setFontSize(8);
  doc.setTextColor(...darkBlue);
  doc.text('CLIENTE', margin + 4, 58);

  doc.setFont('helvetica', 'bold');
  doc.setFontSize(11);
  doc.text(clienteNombre || 'Sin especificar', margin + 4, 65);

  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(80, 90, 110);
  doc.text(clienteContacto ? `Attn: ${clienteContacto}` : '', margin + 4, 71);

  // Greeting
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(60, 70, 90);
  const greeting = 'Reciba un cordial saludo, aprovecho esta oportunidad para presentarle la siguiente cotización de Maquinaria y Equipo, esperando que nuestros precios sean de su agrado.';
  const greetingLines = doc.splitTextToSize(greeting, W - margin * 2);
  doc.text(greetingLines, margin, 83);

  // Table
  const filas = getFilas();
  let item = 1;
  const tableBody = filas.map(f => [
    item++,
    f.desc,
    f.cant.toString(),
    f.unidad,
    `$${f.precio.toFixed(2)}`,
    `$${f.sub.toFixed(2)}`
  ]);

  doc.autoTable({
    startY: 92,
    head: [['#', 'DESCRIPCIÓN', 'CANT.', 'UNIDAD', 'P. UNITARIO', 'SUBTOTAL']],
    body: tableBody,
    margin: { left: margin, right: margin },
    headStyles: {
      fillColor: darkBlue,
      textColor: gold,
      fontStyle: 'bold',
      fontSize: 9,
      halign: 'center',
    },
    columnStyles: {
      0: { halign: 'center', cellWidth: 12 },
      1: { cellWidth: 75 },
      2: { halign: 'center', cellWidth: 18 },
      3: { halign: 'center', cellWidth: 22 },
      4: { halign: 'right', cellWidth: 28 },
      5: { halign: 'right', cellWidth: 28 },
    },
    alternateRowStyles: { fillColor: [240, 242, 248] },
    styles: { fontSize: 9, cellPadding: 4, textColor: darkBlue },
    tableLineColor: [210, 215, 225],
    tableLineWidth: 0.3,
  });

  let y = doc.lastAutoTable.finalY + 6;

  // Totals box
  const subtotal = filas.reduce((s, f) => s + f.sub, 0);
  const iva = subtotal * 0.13;
  const total = subtotal + iva;

  const boxW = 75, boxX = W - margin - boxW;

  doc.setFillColor(...white);
  doc.roundedRect(boxX, y, boxW, 32, 2, 2, 'F');
  doc.setDrawColor(...gold);
  doc.setLineWidth(0.4);
  doc.roundedRect(boxX, y, boxW, 32, 2, 2, 'S');

  doc.setFont('helvetica', 'normal');
  doc.setFontSize(9);
  doc.setTextColor(80, 90, 110);
  doc.text('Subtotal:', boxX + 4, y + 8);
  doc.text(`$${subtotal.toFixed(2)}`, boxX + boxW - 4, y + 8, { align: 'right' });

  doc.text('IVA (13%):', boxX + 4, y + 16);
  doc.text(`$${iva.toFixed(2)}`, boxX + boxW - 4, y + 16, { align: 'right' });

  doc.setDrawColor(...midGray);
  doc.setLineWidth(0.3);
  doc.line(boxX + 4, y + 19, boxX + boxW - 4, y + 19);

  doc.setFont('helvetica', 'bold');
  doc.setFontSize(11);
  doc.setTextColor(...darkBlue);
  doc.text('TOTAL:', boxX + 4, y + 27);
  doc.setTextColor(...gold[0], ...gold.slice(1));
  doc.setTextColor(180, 130, 20);
  doc.text(`$${total.toFixed(2)}`, boxX + boxW - 4, y + 27, { align: 'right' });

  y += 38;

  // Notes
  const notas = document.getElementById('notas').value;
  doc.setFillColor(255, 250, 235);
  doc.roundedRect(margin, y, W - margin * 2 - boxW - 4, 32, 2, 2, 'F');
  doc.setDrawColor(...gold);
  doc.setLineWidth(0.4);
  doc.roundedRect(margin, y, W - margin * 2 - boxW - 4, 32, 2, 2, 'S');

  doc.setFont('helvetica', 'bold');
  doc.setFontSize(8);
  doc.setTextColor(...darkBlue);
  doc.text('NOTAS:', margin + 4, y + 7);
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8);
  doc.setTextColor(80, 90, 110);
  doc.text('• Los precios son más IVA', margin + 4, y + 14);
  doc.text('• Horas de maquinaria: 4 horas mínimas', margin + 4, y + 20);
  if (notas) doc.text(`• ${notas}`, margin + 4, y + 26);

  y += 42;

  // Signature
  doc.setDrawColor(...midGray);
  doc.setLineWidth(0.4);
  doc.line(margin, y + 15, margin + 55, y + 15);
  doc.setFont('helvetica', 'bold');
  doc.setFontSize(9);
  doc.setTextColor(...darkBlue);
  doc.text('Francisco Arístides Mendoza Villalta', margin, y + 20);
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8);
  doc.setTextColor(100, 110, 130);
  doc.text('Representante Legal', margin, y + 25);

  // Footer
  doc.setFillColor(...darkBlue);
  doc.rect(0, H - 14, W, 14, 'F');
  doc.setFillColor(...gold);
  doc.rect(0, H - 14, W, 0.8, 'F');
  doc.setFont('helvetica', 'normal');
  doc.setFontSize(8);
  doc.setTextColor(180, 195, 220);
  doc.text('Inversiones H & L Ingenieros y Arquitectos S.A de C.V', W / 2, H - 8, { align: 'center' });
  doc.text('+503 7528-3295  ·  hylingyarq@yahoo.com', W / 2, H - 4, { align: 'center' });

  // Save
  const nombreCliente = clienteNombre.replace(/[^a-z0-9]/gi, '_').slice(0, 20) || 'Cliente';
  doc.save(`Cotizacion_HyL_${nombreCliente}_${fecha || 'hoy'}.pdf`);
